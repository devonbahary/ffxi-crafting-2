{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": ".",
        "paths": {
            "@ffxi-crafting/db": ["../db/src/index.ts"],
            "@ffxi-crafting/types": ["../types/src/index.ts"]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src"],
    "references": [{ "path": "../db" }, { "path": "../types" }]
}
